# Auto detect text files and normalize line endings to LF in the repository
* text=auto

# Explicitly declare files that should always have LF endings
*.css text eol=lf
*.js text eol=lf
*.html text eol=lf
*.svg text eol=lf
*.php text eol=lf

# Declare files that are binary and should not be modified
*.png binary
*.jpg binary
*.gif binary
*.mp4 binary
*.webm binary

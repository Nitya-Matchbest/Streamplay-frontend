   .new-sticky {
       display: none
   }

   div.dots {
       display: inline-flex
   }

   div.dots span {
       width: 5px;
       height: 5px;
       border-radius: 50%;
       background: #000;
       position: relative;
       animation: wave 1.3s linear infinite;
       margin-right: 2px
   }

   div.dots span:first-child {
       background: #ff0935
   }

   div.dots span:nth-child(2) {
       background: #ffd119;
       animation-delay: -1.1s
   }

   div.dots span:last-child {
       background: #0dcea6;
       animation-delay: -.9s
   }

   @keyframes wave {
       0%,
       100%,
       60% {
           transform: initial
       }
       30% {
           transform: translateY(-10px) !important
       }
   }


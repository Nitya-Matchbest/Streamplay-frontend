}),

  $(window).width() <= 768 &&
    ($("body").removeClass("transparent-header"), $(".wow").removeClass("wow")),
  $(window).width() >= 768 &&
    $(window).scroll(function () {
      $(window).scrollTop() >= 150
        ? $(".page-level-menu").addClass("menu-fixed")
        : $(".page-level-menu").removeClass("menu-fixed");
    }),
  $(document).ready(function () {
    var e = window.location.hash;
    "" != e &&
      ((Top = 110),
      "#multi-formats-codecs" == e
        ? (Top = 110)
        : "#subscription" == e
        ? (Top = 0)
        : "#encryption" == e
        ? (Top = 110)
        : "#meta-data" == e && (Top = -80),
      $("html, body").animate({ scrollTop: $(e).offset().top - Top }, 100));
  });
const nav = document.querySelector("#vplayed-menu"),
  navTop = nav.offsetTop;
function stickyNavigation() {
  window.scrollY > navTop
    ? nav.classList.add("fixed-header")
    : nav.classList.remove("fixed-header");
}


window.addEventListener("scroll", stickyNavigation),
  $(window).width() <= 1200 &&
    $(".dropmenu-new").click(function () {
      var child = $(this).children(".submenu"),
        rest = $(".submenu:visible").not(child);
      child.slideToggle(), rest.slideUp();
    }),
  $(document).ready(function () {
    $("#popup-deposit").delay(15e3).fadeIn(400),
      $("#popup-deposit").delay(15e3).fadeIn(400),
      $("#sdfsd").on("click", function (e) {

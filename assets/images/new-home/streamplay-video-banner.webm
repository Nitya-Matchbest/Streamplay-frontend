   .vplayed-menu .nav-menu li.dropmenu-new .submenu:before {
       content: "";
       position: absolute;
       top: -5px;
       left: 18%;
       width: 18px;
       height: 18px;
       z-index: 0;
       background: #fff;
       transform: rotate(45deg);
       transition: .5s ease
   }

   .vplayed-menu .nav-menu li.dropmenu-new .submenu.small:before {
       left: 48%
   }

   .vplayed-menu .nav-menu li.dropmenu-new:nth-child(2) .submenu:before {
